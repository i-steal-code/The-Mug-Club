# Supabase: Project Settings → Database → Connection string
# Render: set DATABASE_URL on the Web Service (do not commit real secrets).
#
# --- Recommended for Render / IPv4-only networks (Session pooler) ---
# Supabase documents: "Session pooler connections are IPv4 proxied". User is not "postgres"
# but postgres.<project-ref> (see your dashboard). Example shape:
# postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
# Pick the host/region shown in your project (e.g. aws-0-... or aws-1-... ap-southeast-1).
# Username is one string:  postgres.<project-ref>  (not the separate "Direct" user "postgres" only).
#
# --- Direct connection (often OK locally; on Render can hit IPv6 routing issues) ---
# postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# Use the URI exactly as Supabase shows. If the password has @ : / ? # [ ] & , URL-encode it.
# Brackets [ ] only surround literal IPv6 addresses, never the db/pooler hostname.

DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Flask session signing (set a long random string in production)
SECRET_KEY=_____________________
