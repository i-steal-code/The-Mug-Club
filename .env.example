# Supabase: Project Settings → Database → Connection string (URI)
# Render: set DATABASE_URL on the Web Service (do not commit real secrets).
#
# Use the string exactly as Supabase shows (no [ ] around hostnames; brackets are only
# for literal IPv6). If the password has @ : / ? # [ ] & , URL-encode or reset the password.
#
# Direct host db.<project>.supabase.co:5432 — the app prefers IPv4 (helps on Render).
# Alternative: "Connection pooling" / Session pooler URI.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Flask session signing (set a long random string in production)
SECRET_KEY=_____________________
